#include "config.h"

#include "xkbcommon/xkbcommon.h"
#include "enums.h"
#include "utils.h"

static bool
is_supported_enum_value_mask(enum xkb_enumerations_values values, int value)
{
    return (value >= 0 && value < INT_WIDTH && (values & (1u << value)));
}

static bool
is_supported_enum_value_array(const int *values, size_t size, int value)
{
    for (size_t v = 0; v < size; v++) {
        if (values[v] == value) {
            return true;
        }
    }
    return false;
}

static bool
is_supported_flag_value(enum xkb_enumerations_values values, int value)
{
    return ((int) values & value) == value;
}

bool
xkb_has_feature(enum xkb_feature feature, int value)
{
    switch (feature) {
    {# TODO: Non-enumeration features #}
    {# Enumerations #}
    {% for entry in enum_data["xkb_feature"] %}
    case {{ entry.name }}:
        {% set enum = entry.name.replace("_FEATURE_ENUM_", "_").lower() %}
        {% set entries = enum_data[enum] %}
        {% if is_flag(entries) %}
            {% if has_zero(entries) %}
        return is_supported_flag_value({{enum.upper() + "_VALUES"}}, value);
            {% else %}
        return value && is_supported_flag_value({{enum.upper() + "_VALUES"}}, value);
            {% endif %}
        {% elif has_values_mask(entries) %}
        return is_supported_enum_value_mask({{enum.upper() + "_VALUES"}}, value);
        {% else %}
        return is_supported_enum_value_array(
            {{enum.lower() + "_values"}},
            ARRAY_SIZE({{enum + "_values"}}),
            value
        );
        {% endif %}
    {% endfor %}
    default:
        /* Invalid feature */
        return false;
    }
}
