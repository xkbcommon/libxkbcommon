xkb_symbols "keysyms_and_actions_extras_xkbcommon_new" {

	// base:     symbols=[a, NoSymbol], actions=[NoAction(), SetGroup(group=2)]
	key <AE01> { symbols=[NoSymbol, {X, Y}], actions=[{SetGroup(group=3), SetMods(mods=Mod5)}, NoAction()] };
