	////// Multiple keysyms/actions –> single //////

	// base:     symbols=[{a, b}, NoSymbol], actions=[NoAction(), {SetGroup(group=2), SetMods(mods=Control)}]
	key <AE02> { symbols=[NoSymbol, X], actions=[SetGroup(group=3), NoAction()] };
